# SmartBrew Landing Backend — environment example.
# Copy to `.env` and fill in. `.env` is gitignored.

# Reload release manifests on every request (dev only). Defaults to false.
DEBUG=false

# Used to salt the IP hash for contact submissions. CHANGE THIS in production.
SECRET=dev-secret-change-me

# Shared secret for POST /api/v1/admin/releases/reload (X-Admin-Token header).
ADMIN_TOKEN=dev-admin-token-change-me

# SQLite by default; swap for Postgres in production.
DATABASE_URL=sqlite:///./landing.db

# Comma-separated CORS allowlist (production landing origin + localhost dev).
CORS_ORIGINS=https://smartbrew.app,http://localhost:4321,http://localhost:4322,http://localhost:4323,http://localhost:5173

# Optional SMTP — if SMTP_HOST is unset, contact messages are stored only.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@smartbrew.app
CONTACT_TO=team@smartbrew.app

# Newsletter double opt-in (generates a confirm token instead of instant confirm).
NEWSLETTER_DOUBLE_OPT_IN=false
