---
// Sticky top navigation. Transparent over the (light) hero, then turns to a
// blurred light bar on scroll. Dark text throughout (hero is a light scene).
// On phones the section links collapse into a tap-to-open menu panel.
import type { Locale } from '../lib/i18n'
import LanguageToggle from './LanguageToggle'

const { lang = 'th' } = Astro.props as { lang?: Locale }

const COPY = {
  th: { features: 'ความสามารถ', ai: 'AI', backoffice: 'หลังร้าน', pricing: 'ราคา', faq: 'คำถาม', download: 'ดาวน์โหลด', menu: 'เปิดเมนู' },
  en: { features: 'Features', ai: 'AI', backoffice: 'Back-office', pricing: 'Pricing', faq: 'FAQ', download: 'Download', menu: 'Open menu' },
}
const t = COPY[lang]
const home = lang === 'en' ? '/en/' : '/'
const links = [
  { label: t.features, href: '#features' },
  { label: t.ai, href: '#ai' },
  { label: t.backoffice, href: '#backoffice' },
  { label: t.pricing, href: '#pricing' },
  { label: t.faq, href: '#faq' },
]
---

<header id="site-header" class="fixed inset-x-0 top-0 z-40 transition-colors duration-300">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-6 py-4">
    <a href={home} class="font-display text-lg tracking-tightest text-text">
      SmartBrew<span class="text-primary"> POS</span>
    </a>

    <nav class="hidden items-center gap-8 md:flex" aria-label="Primary">
      {
        links.map((link) => (
          <a href={link.href} class="text-sm text-text-muted transition-colors hover:text-text">
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <div class="hidden text-sm md:block">
        <LanguageToggle locale={lang} client:idle />
      </div>
      <a
        href="#download"
        class="hidden rounded-full bg-primary px-5 py-2.5 text-sm font-medium text-primary-fg shadow-card transition-transform duration-200 hover:-translate-y-0.5 md:inline-flex"
      >
        {t.download}
      </a>

      <button
        id="menu-toggle"
        type="button"
        class="flex h-10 w-10 items-center justify-center rounded-full border border-border bg-surface/70 text-text backdrop-blur transition-colors hover:bg-surface md:hidden"
        aria-label={t.menu}
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="menu-icon-open h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" />
        </svg>
        <svg class="menu-icon-close hidden h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" aria-hidden="true">
          <path d="M6 6l12 12M18 6 6 18" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden bg-surface/95 backdrop-blur md:hidden">
    <nav class="mx-auto flex max-w-7xl flex-col px-6 pb-5 pt-1" aria-label="Mobile">
      {
        links.map((link) => (
          <a
            href={link.href}
            data-menu-link
            class="rounded-xl px-3 py-3 text-base text-text transition-colors hover:bg-surface-2"
          >
            {link.label}
          </a>
        ))
      }
      <div class="mt-3 flex items-center justify-between border-t border-border pt-4">
        <div class="text-sm">
          <LanguageToggle locale={lang} client:idle />
        </div>
        <a
          href="#download"
          data-menu-link
          class="rounded-full bg-primary px-6 py-2.5 text-sm font-medium text-primary-fg shadow-card"
        >
          {t.download}
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('site-header')
  const toggle = document.getElementById('menu-toggle')
  const menu = document.getElementById('mobile-menu')

  const syncSolid = () => {
    if (!header) return
    const open = menu ? !menu.classList.contains('hidden') : false
    header.classList.toggle('site-header--solid', open || window.scrollY > 24)
  }

  syncSolid()
  window.addEventListener('scroll', syncSolid, { passive: true })

  if (toggle && menu) {
    const openIcon = toggle.querySelector('.menu-icon-open')
    const closeIcon = toggle.querySelector('.menu-icon-close')
    const setOpen = (open: boolean) => {
      menu.classList.toggle('hidden', !open)
      toggle.setAttribute('aria-expanded', String(open))
      openIcon?.classList.toggle('hidden', open)
      closeIcon?.classList.toggle('hidden', !open)
      syncSolid()
    }
    toggle.addEventListener('click', () => setOpen(menu.classList.contains('hidden')))
    menu.querySelectorAll('[data-menu-link]').forEach((link) => {
      link.addEventListener('click', () => setOpen(false))
    })
    // Close the menu if the viewport grows to desktop.
    window.matchMedia('(min-width: 768px)').addEventListener('change', (e) => {
      if (e.matches) setOpen(false)
    })
  }
</script>
