---
// Sticky top navigation. Transparent over the (light) hero, then turns to a
// blurred light bar on scroll. Dark text throughout (hero is a light scene).
import type { Locale } from '../lib/i18n'
import LanguageToggle from './LanguageToggle'

const { lang = 'th' } = Astro.props as { lang?: Locale }

const COPY = {
  th: { features: 'ความสามารถ', ai: 'AI', backoffice: 'หลังร้าน', pricing: 'ราคา', faq: 'คำถาม', download: 'ดาวน์โหลด' },
  en: { features: 'Features', ai: 'AI', backoffice: 'Back-office', pricing: 'Pricing', faq: 'FAQ', download: 'Download' },
}
const t = COPY[lang]
const home = lang === 'en' ? '/en/' : '/'
const links = [
  { label: t.features, href: '#features' },
  { label: t.ai, href: '#ai' },
  { label: t.backoffice, href: '#backoffice' },
  { label: t.pricing, href: '#pricing' },
  { label: t.faq, href: '#faq' },
]
---

<header id="site-header" class="fixed inset-x-0 top-0 z-40 transition-colors duration-300">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-6 py-4">
    <a href={home} class="font-display text-lg tracking-tightest text-text">
      SmartBrew<span class="text-primary"> POS</span>
    </a>

    <nav class="hidden items-center gap-8 md:flex" aria-label="Primary">
      {
        links.map((link) => (
          <a href={link.href} class="text-sm text-text-muted transition-colors hover:text-text">
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-4">
      <div class="hidden text-sm sm:block">
        <LanguageToggle locale={lang} client:idle />
      </div>
      <a
        href="#download"
        class="rounded-full bg-primary px-5 py-2.5 text-sm font-medium text-primary-fg shadow-card transition-transform duration-200 hover:-translate-y-0.5"
      >
        {t.download}
      </a>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('site-header')
  if (header) {
    const onScroll = () => header.classList.toggle('site-header--solid', window.scrollY > 24)
    onScroll()
    window.addEventListener('scroll', onScroll, { passive: true })
  }
</script>
