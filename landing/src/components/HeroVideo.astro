---
// Act I hero (landing brief §5.2) — bright studio clip. Plays once and freezes
// on the last frame; the headline reveals only after the video ends (it
// dispatches `hero:reveal`). Phones get a lighter `hero-mobile.mp4` and play it
// inline; reduced motion or blocked autoplay reveal immediately and rest on the
// final still. Light scene -> dark text + light scrim.
---

<section class="relative h-[100svh] w-full overflow-hidden">
  <video
    class="absolute inset-0 h-full w-full object-cover"
    muted
    playsinline
    preload="auto"
    poster="/video/hero-poster.webp"
    aria-hidden="true"
    data-hero-video
  >
    <source src="/video/hero.webm" type="video/webm" media="(min-width: 768px)" />
    <source src="/video/hero.mp4" type="video/mp4" media="(min-width: 768px)" />
    <source src="/video/hero-mobile.mp4" type="video/mp4" media="(max-width: 767px)" />
    <source src="/video/hero-mobile.mp4" type="video/mp4" />
  </video>

  <!-- Light readability scrim on the text side: keeps the dark headline crisp on
       the white studio background without darkening the clean look. -->
  <div
    class="absolute inset-0 bg-gradient-to-r from-white/70 via-white/25 to-transparent"
    aria-hidden="true"
  >
  </div>

  <div class="relative z-10 flex h-full items-center">
    <slot />
  </div>
</section>

<script>
  const video = document.querySelector<HTMLVideoElement>('video[data-hero-video]')
  let revealed = false
  let fallback = 0
  const reveal = () => {
    if (revealed) return
    revealed = true
    window.clearTimeout(fallback)
    window.__heroRevealed = true
    window.dispatchEvent(new CustomEvent('hero:reveal'))
  }

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches

  if (!video || reduce) {
    if (video) video.poster = '/video/hero-end.webp' // rest on the final frame
    reveal()
  } else {
    video.addEventListener('ended', reveal, { once: true })
    fallback = window.setTimeout(reveal, 12000) // safety if 'ended' never fires
    // Muted + playsinline autoplays inline on iOS/Android; if it's still blocked
    // (data saver, low-power mode) fall back to the still and reveal the copy.
    const played = video.play()
    if (played && typeof played.catch === 'function') {
      played.catch(() => {
        video.poster = '/video/hero-end.webp'
        reveal()
      })
    }
  }
</script>
