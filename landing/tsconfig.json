{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src", "tests", "*.config.ts", "*.config.mjs", "vitest.setup.ts", ".astro/types.d.ts"],
  "exclude": ["dist", "node_modules", "e2e", "playwright.config.ts"]
}
