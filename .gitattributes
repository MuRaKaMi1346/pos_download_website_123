# Normalize line endings to LF in the repo; check out native on each platform.
* text=auto eol=lf

# Treat binary assets as binary (no EOL conversion, no diff).
*.png  binary
*.jpg  binary
*.jpeg binary
*.webp binary
*.gif  binary
*.ico  binary
*.mp4  binary
*.webm binary
*.glb  binary
*.opus binary
*.mp3  binary
*.woff  binary
*.woff2 binary
